---
import '../styles/global.css';
import '../styles/section.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const { title = 'Hossam Emad | Embedded Hardware Engineer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Embedded hardware engineer portfolio showcasing PCB design, firmware, industrial IoT, and automotive electronics projects." />
    <meta name="theme-color" content="#050816" />
    <title>{title}</title>
  </head>
  <body>
    <Navigation />
    <slot />
    <Footer />
  </body>
</html>
