---
import Layout from '../../layouts/Layout.astro';
import { featuredProjects } from '../../data/projects';

export function getStaticPaths() {
  return featuredProjects.map((project) => ({
    params: { slug: project.href.split('/').pop() },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Hossam Emad`}>
  <main class="mx-auto max-w-5xl px-6 py-20 lg:px-8">
    <section class="rounded-3xl border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-slate-950/50">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Case Study</p>
      <h1 class="mt-4 text-4xl font-semibold text-white">{project.title}</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">{project.summary}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        {project.tags.map((tag) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-slate-300">{tag}</span>
        ))}
      </div>
    </section>
  </main>
</Layout>
