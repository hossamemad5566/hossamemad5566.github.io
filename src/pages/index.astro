---
import Layout from '../layouts/Layout.astro';
import { featuredProjects } from '../data/projects';
---

<Layout>
  <main>
    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-8 lg:py-32">
      <div class="grid items-center gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:gap-14">
        <div class="max-w-3xl">
          <p class="text-base font-semibold uppercase tracking-[0.35em] text-sky-300">Embedded Systems / Hardware Engineering</p>
          <h1 class="mt-5 text-5xl font-semibold leading-[1.05] text-white sm:text-6xl lg:text-7xl">Designing reliable electronics from prototype to production.</h1>
          <p class="mt-6 text-2xl leading-9 text-slate-200 sm:text-[1.65rem]">
            I build embedded hardware, PCB layouts, and firmware for industrial automation, automotive telematics, and IoT products with a strong focus on field reliability.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#projects" class="rounded-full bg-sky-500 px-8 py-4 text-xl font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-sky-400">View Projects</a>
            <a href="/Hossam_Emad_Mohamed_Osman_Detailed_CV.pdf" class="rounded-full border border-white/15 px-8 py-4 text-xl font-semibold text-slate-200 transition hover:-translate-y-0.5 hover:bg-white/10">Download CV</a>
          </div>
        </div>
        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900/70 shadow-[0_20px_80px_rgba(2,6,23,0.55)]">
          <img src="/images/hero/pcb-hero.png" alt="PCB hardware layout" class="h-72 w-full object-cover" />
          <div class="p-8">
            <h2 class="text-3xl font-semibold text-white">Engineering focus</h2>
            <div class="mt-5 grid gap-3 text-lg text-slate-200 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">4-layer PCB design and controlled impedance routing</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Embedded firmware and RTOS-based product development</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">BMS and power electronics validation</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Industrial and automotive hardware delivery</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="border-t border-white/10">
      <div class="mx-auto grid max-w-7xl gap-8 px-6 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:px-8">
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-sky-300">About</p>
          <h2 class="section-heading">Professional engineering profile</h2>
        </div>
        <div class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-8">
          <p class="section-copy">
            I combine hardware design, firmware delivery, and manufacturing awareness to create dependable electronic products from first prototypes through production-ready systems, with hands-on experience supporting deployed devices and resolving field issues.
          </p>
        </div>
      </div>
    </section>

    <section id="skills" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Skills</p>
        <h2 class="section-heading">Core capabilities</h2>
        <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {['PCB Design', 'Embedded C', 'FreeRTOS', 'Signal Integrity', 'BMS', 'CAN', 'ESP32', 'STM32'].map((skill) => (
            <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-6 text-lg font-medium text-slate-100">{skill}</div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Projects</p>
        <h2 class="section-heading">Featured engineering case studies</h2>
        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <article class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-slate-900/70 shadow-[0_14px_50px_rgba(2,6,23,0.38)] transition hover:-translate-y-1 hover:border-sky-400/30">
              <div class={`h-48 bg-gradient-to-br ${project.accent} p-4`}>
                <img src={project.image} alt={project.title} class="h-full w-full rounded-[1rem] object-cover" />
              </div>
              <div class="p-6">
                <h3 class="text-2xl font-semibold text-white">{project.title}</h3>
                <p class="mt-3 text-lg leading-8 text-slate-200">{project.summary}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-full border border-sky-400/20 bg-sky-500/10 px-3 py-1.5 text-sm font-medium text-sky-200">{tag}</span>
                  ))}
                </div>
                <a href={project.href} class="mt-6 inline-flex text-base font-semibold text-sky-300 transition hover:text-sky-200">Read case study →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="timeline" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Timeline</p>
        <h2 class="section-heading">Career progression</h2>
        <div class="mt-8 space-y-5 rounded-[1.75rem] border border-white/10 bg-slate-900/70 p-8">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-xl font-semibold text-white">2017 — 2022 — Bachelor of Electronics and Control Engineering</p>
            <p class="mt-2 text-lg leading-8 text-slate-200">Completed studies at Menoufia University with a very good grade and a strong foundation in electronics, control, and embedded systems.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-xl font-semibold text-white">2024 — Automotive Embedded Systems Diploma at NTI</p>
            <p class="mt-2 text-lg leading-8 text-slate-200">Built advanced experience in embedded C, RTOS, automotive communication protocols, and hands-on development workflows.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-xl font-semibold text-white">2024 — Present — Embedded Systems Engineer at SEITech</p>
            <p class="mt-2 text-lg leading-8 text-slate-200">Delivering hardware design, firmware development, production support, and field troubleshooting for industrial and IoT products.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
