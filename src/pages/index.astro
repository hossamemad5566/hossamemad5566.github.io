---
import Layout from '../layouts/Layout.astro';
import { featuredProjects } from '../data/projects';

const skillGroups = [
  {
    label: 'Firmware & Software',
    skills: ['Embedded C (production-grade)', 'FreeRTOS', 'Python (prototyping & validation)', 'SMS / MQTT / HTTP', 'GPS data processing', 'FOTA', 'Geofencing algorithms', 'Root-cause analysis'],
  },
  {
    label: 'Hardware & PCB',
    skills: ['Multi-layer PCB design (up to 4 layers)', 'Stackup planning & controlled impedance (USB, CAN, RF)', 'EMI mitigation', 'RF subsystem design', 'Battery Management Systems (3-cell)', 'Board bring-up & field debugging', 'Gerber / BOM / CPL preparation', 'Fab coordination (JLCPCB)'],
  },
  {
    label: 'Protocols & Interfaces',
    skills: ['CAN (High-Speed, SWCAN)', 'USB', 'UART / SPI / I²C', 'RS232 / RS485', 'Wi-Fi / BLE', '4G (SIMCom)', 'ADC / GPIO'],
  },
  {
    label: 'Tools',
    skills: ['Altium Designer', 'KiCad', 'EAGLE', 'EasyEDA Pro', 'Autodesk Fusion 360', 'LTspice'],
  },
];

const timeline = [
  {
    period: 'Jul 2024 — Present',
    title: 'Embedded Systems Engineer',
    org: 'SEITech Solutions (Acquired by T&S Group), Smart Village, Cairo',
    body: 'Own full product lifecycle — concept through manufacturing and deployment — across SEIFence IoT trackers, ForWheelz automotive telematics, the SEITech Box industrial gateway and BMS, an Ethernet/RS485 access control board, a Wi-Fi smart switch, and an STM32F407 + ESP32-S3 industrial IoT controller platform.',
  },
  {
    period: 'Jan 2024 — Feb 2024',
    title: 'Embedded Systems Engineer (Short-term contract)',
    org: 'Noziqs Medical, Nasr City',
    body: 'Developed embedded firmware for operating tables, improving system functionality by 30% and reducing device downtime by 20% through board-level troubleshooting and root-cause analysis.',
  },
  {
    period: 'Feb 2024 — Jul 2024',
    title: 'Automotive Embedded Systems Diploma',
    org: 'NTI, New Capital',
    body: 'Embedded C, RTOS, STM32 & AVR, CAN/LIN/UART/SPI/I2C, bootloader/FOTA, automotive testing, and project management — graduation project: a custom STM32F407 + ESP32-S3 industrial IoT controller platform.',
  },
  {
    period: 'Sep 2017 — Jul 2022',
    title: 'B.Sc. Electronics and Control Engineering',
    org: 'Menoufia University — Grade: Very Good',
    body: 'Built the analog/digital electronics and control-systems foundation for a career in embedded hardware, going on to complete the NTI Automotive Embedded Systems Diploma before transitioning to industry.',
  },
];
---

<Layout>
  <main>
    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-8 lg:py-32">
      <div class="grid items-center gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:gap-14">
        <div class="max-w-3xl">
          <p class="text-base font-semibold uppercase tracking-[0.35em] text-sky-300">Embedded Systems / Hardware Engineer</p>
          <h1 class="mt-5 text-5xl font-semibold leading-[1.05] text-white sm:text-6xl lg:text-7xl">Designing dependable electronics from concept to production.</h1>
          <p class="mt-6 text-2xl leading-9 text-slate-200 sm:text-[1.65rem]">
            2+ years turning field problems into shipped hardware — 4-layer PCB design, RTOS firmware, EMI mitigation, and BMS for automotive and industrial IoT systems, with full lifecycle ownership from concept through manufacturing and deployment.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#projects" class="rounded-full bg-sky-500 px-8 py-4 text-xl font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-sky-400">View Projects</a>
            <a href="/resume" class="rounded-full border border-white/15 px-8 py-4 text-xl font-semibold text-slate-200 transition hover:-translate-y-0.5 hover:bg-white/10">Download Resume</a>
          </div>
          <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-base text-slate-300">
            <span>Giza, Egypt</span>
            <a href="mailto:hossam.emad.5566@gmail.com" class="transition hover:text-sky-300">hossam.emad.5566@gmail.com</a>
            <a href="tel:+201015891738" class="transition hover:text-sky-300">+20 101 589 1738</a>
          </div>
        </div>
        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900/70 shadow-[0_20px_80px_rgba(2,6,23,0.55)]">
          <img src="/images/hero/pcb-hero.png" alt="PCB hardware layout" class="h-72 w-full object-cover" />
          <div class="p-8">
            <h2 class="text-3xl font-semibold text-white">Engineering focus</h2>
            <div class="mt-5 grid gap-3 text-lg text-slate-200 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">4-layer PCB & signal integrity</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">RTOS firmware (FreeRTOS)</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">BMS & power electronics</div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Automotive & industrial IoT</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="border-t border-white/10">
      <div class="mx-auto grid max-w-7xl gap-8 px-6 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:px-8">
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-sky-300">About</p>
          <h2 class="section-heading">Professional engineering profile</h2>
        </div>
        <div class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-8">
          <p class="section-copy">
            Embedded Systems Engineer with 2+ years of hands-on experience in hardware design, PCB layout, firmware development, and production support. I independently identify field issues, propose solutions, and deliver improved hardware and firmware revisions end-to-end — with experience across automotive and industrial IoT systems, 4-layer high-speed PCB design, EMI mitigation, controlled impedance routing, BMS, and RTOS-based firmware, owning the full product lifecycle from concept through manufacturing and deployment.
          </p>
        </div>
      </div>
    </section>

    <section id="skills" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Skills</p>
        <h2 class="section-heading">Core capabilities</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {skillGroups.map((group) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-slate-900/70 p-6">
              <h3 class="text-xl font-semibold text-sky-300">{group.label}</h3>
              <div class="mt-4 flex flex-wrap gap-2">
                {group.skills.map((skill) => (
                  <span class="rounded-full border border-white/10 bg-white/5 px-3.5 py-2 text-base font-medium text-slate-100">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Projects</p>
        <h2 class="section-heading">Featured engineering case studies</h2>
        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <article class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-slate-900/70 shadow-[0_14px_50px_rgba(2,6,23,0.38)] transition hover:-translate-y-1 hover:border-sky-400/30">
              <div class={`h-48 bg-gradient-to-br ${project.accent} p-4`}>
                <img src={project.image} alt={project.title} class="h-full w-full rounded-[1rem] object-cover" />
              </div>
              <div class="p-6">
                <h3 class="text-2xl font-semibold text-white">{project.title}</h3>
                <p class="mt-3 text-lg leading-8 text-slate-200">{project.summary}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-full border border-sky-400/20 bg-sky-500/10 px-3 py-1.5 text-sm font-medium text-sky-200">{tag}</span>
                  ))}
                </div>
                <a href={project.href} class="mt-6 inline-flex text-base font-semibold text-sky-300 transition hover:text-sky-200">Read case study →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="timeline" class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Timeline</p>
        <h2 class="section-heading">Career progression</h2>
        <div class="mt-8 space-y-5 rounded-[1.75rem] border border-white/10 bg-slate-900/70 p-8">
          {timeline.map((item) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-300">{item.period}</p>
              <p class="mt-2 text-xl font-semibold text-white">{item.title}</p>
              <p class="mt-1 text-base font-medium text-slate-400">{item.org}</p>
              <p class="mt-3 text-lg leading-8 text-slate-200">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
