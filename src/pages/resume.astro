---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Hossam Emad">
  <main class="mx-auto max-w-5xl px-6 py-20 lg:px-8">
    <section class="rounded-3xl border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-slate-950/50">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Resume</p>
      <h1 class="mt-4 text-4xl font-semibold text-white">Embedded systems engineer with hardware, firmware, and production experience</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        This page is prepared for the downloadable CV and supporting experience summary. It is ready to be expanded with the full PDF and detailed career chronology.
      </p>
      <a href="/Hossam_Emad_Mohamed.pdf" class="mt-8 inline-flex rounded-full border border-sky-400/40 bg-sky-500/10 px-6 py-3 font-medium text-sky-300 transition hover:bg-sky-500/20">Download CV</a>
    </section>
  </main>
</Layout>
