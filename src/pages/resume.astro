---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Hossam Emad">
  <main class="mx-auto max-w-5xl px-6 py-20 lg:px-8">
    <section class="rounded-3xl border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-slate-950/50">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Resume</p>
      <h1 class="mt-4 text-4xl font-semibold text-white sm:text-5xl">Embedded systems engineer with hardware, firmware, and production experience</h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-300">
        The detailed CV covers embedded hardware design, PCB development, RTOS firmware, industrial IoT products, automotive telematics, and production support across multiple deployed systems.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/Hossam_Emad_Mohamed_Osman_Detailed_CV.pdf" class="inline-flex rounded-full border border-sky-400/40 bg-sky-500/10 px-7 py-4 text-lg font-semibold text-sky-300 transition hover:bg-sky-500/20">Download detailed CV</a>
        <a href="/" class="inline-flex rounded-full border border-white/15 px-7 py-4 text-lg font-semibold text-slate-200 transition hover:bg-white/10">Back to portfolio</a>
      </div>
    </section>
  </main>
</Layout>
