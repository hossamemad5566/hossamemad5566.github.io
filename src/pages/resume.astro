---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Hossam Emad">
  <main class="mx-auto max-w-5xl px-6 py-20 lg:px-8">
    <section class="rounded-3xl border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-slate-950/50">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-300">Resume</p>
      <h1 class="mt-4 text-4xl font-semibold text-white sm:text-5xl">Embedded Systems / Hardware Engineer</h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-300">
        2+ years of hands-on experience in hardware design, PCB layout, firmware development, and production support — across automotive telematics, industrial IoT, BMS, and RTOS-based firmware, with full product lifecycle ownership from concept through manufacturing and deployment.
      </p>
      <a href="/Hossam_Emad_Mohamed_Osman.pdf" download class="mt-8 inline-flex rounded-full border border-sky-400/40 bg-sky-500/10 px-7 py-4 text-lg font-semibold text-sky-300 transition hover:bg-sky-500/20">Download CV (PDF)</a>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-3xl border border-white/10 bg-slate-900/60 p-8">
        <h2 class="text-2xl font-semibold text-white">Experience</h2>
        <div class="mt-5 space-y-5 text-lg leading-8 text-slate-200">
          <div>
            <p class="font-semibold text-white">Embedded Systems Engineer</p>
            <p class="text-base text-slate-400">SEITech Solutions (Acquired by T&amp;S Group) · Jul 2024 – Present</p>
            <p class="mt-1">Full lifecycle ownership of SEIFence, ForWheelz, SEITech Box, its BMS, an access control board, a smart Wi-Fi switch, and an industrial IoT controller platform.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Embedded Systems Engineer (contract)</p>
            <p class="text-base text-slate-400">Noziqs Medical · Jan 2024 – Feb 2024</p>
            <p class="mt-1">Embedded firmware for operating tables — 30% functionality improvement, 20% less downtime.</p>
          </div>
        </div>
      </div>
      <div class="rounded-3xl border border-white/10 bg-slate-900/60 p-8">
        <h2 class="text-2xl font-semibold text-white">Education &amp; Certifications</h2>
        <div class="mt-5 space-y-5 text-lg leading-8 text-slate-200">
          <div>
            <p class="font-semibold text-white">B.Sc. Electronics and Control Engineering</p>
            <p class="text-base text-slate-400">Menoufia University · Sep 2017 – Jul 2022 · Grade: Very Good</p>
          </div>
          <div>
            <p class="font-semibold text-white">Automotive Embedded Systems Diploma</p>
            <p class="text-base text-slate-400">NTI, New Capital · Feb 2024 – Jul 2024</p>
          </div>
          <div>
            <p class="font-semibold text-white">Crash Course Electronics &amp; PCB Design</p>
            <p class="text-base text-slate-400">Udemy · 112 hours · Jan 2026</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
